" bookmark this file
nnoremap <leader>0 :tabnew $HOME/dotfiles/bookmarks.vim<cr>

" config files: open in new tab
nnoremap <leader>1 :tabnew $HOME/dotfiles/vimrc<cr>
nnoremap <leader>2 :tabnew $HOME/dotfiles/init.vim<cr>
nnoremap <leader>3 :tabnew $HOME/.config/nvim/init.vim<cr>
nnoremap <leader>4 :tabnew $HOME/dotfiles/tmux.conf<cr>
nnoremap <leader>5 :tabnew $HOME/dotfiles/zshrc<cr>
